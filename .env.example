# Required for Google GenAI (Gemini)
GOOGLE_API_KEY=

# Optional override
GOOGLE_MODEL=gemini-1.5-flash

# Optional model used only for dynamic session titles
TITLE_MODEL=gemini-3.1-flash-lite-preview

# Required for Tavily web search
TAVILY_API_KEY=

# Optional: required if using LangGraph Studio / LangSmith
LANGSMITH_API_KEY=

# Optional: Langfuse (self-hosted or cloud)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# For self-hosted or non-default region:
LANGFUSE_HOST=http://your-langfuse-host:3000
# Alternative env key some setups use:
LANGFUSE_BASE_URL=http://your-langfuse-host:3000
# Optional: reduce dashboard latency (lower = faster, more network overhead)
LANGFUSE_FLUSH_INTERVAL=1
LANGFUSE_FLUSH_AT=1

# Optional server port
PORT=8000
